        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Основная часть эксперимента подошла к концу. Половина экранов, которые Вы видели, повторялась в течение эксперимента. Сейчас Вам будет показано 12 экранов, которые повторялись в течение эксперимента, и 12 совершенно новых экранов. &amp;#10;&amp;#10;Нажмите клавишу со стрелкой, чтобы ответить, предъявлялся ли этот экран ранее: &amp;#10;стрелка влево (&lt;-), если экран НЕ предъявлялся и Вы видите его впервые;&amp;#10;стрелка вправо (-&gt;), если экран ранее предъявлялся несколько раз в течение эксперимента. &amp;#10;&amp;#10;Пожалуйста, отвечайте как можно точнее.&amp;#10;&amp;#10;Нажмите ПРОБЕЛ, чтобы перейти к заданию." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="code" updates="None" name="validator"/>
        <Param val="" valType="num" updates="constant" name="wrapWidth"/>
